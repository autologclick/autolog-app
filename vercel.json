  "buildCommand": "prisma generate && next build",
  "outputDirectory": ".next",
  "installCommand": "npm install && prisma generate",
  "framework": "nextjs",
  "regions": ["fra1"],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "env": {
    "NODE_ENV": "production"
  }
}
