{
  "buildCommand": "npx prisma generate && npx prisma db push && next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": [
    "fra1"
  ],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "env": {
    "NODE_ENV": "production"
  },
  "crons": [
    {
      "path": "/api/cron/send-reminders",
      "schedule": "0 7 * * *"
    }
  ]
}
