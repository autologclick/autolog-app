# Database (PostgreSQL)
# Local development: postgresql://user:password@localhost:5432/autolog
# Vercel Postgres: Get from Vercel dashboard
DATABASE_URL="postgresql://user:password@host:5432/autolog?schema=public"

JWT_SECRET="your-secret-key-change-this-in-production"
NEXT_PUBLIC_APP_URL="https://autolog.click"

# WhatsApp Integration (Twilio)
# Get these from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+1234567890

# Web Push Notifications (VAPID)
# Generate keys at https://web-push-codelab.glitch.me/
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@autolog.local

# Maps Integration
# Choose between 'google' or 'mapbox'
MAPS_API_KEY=
MAPS_PROVIDER=google

# Payment Processing (Stripe)
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=price_xxxxx
