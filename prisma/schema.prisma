generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?
  passwordHash  String
  fullName      String
  idNumber      String?   @unique
  licenseNumber String?
  role          String    @default("user") // user | admin | garage_owner
  avatarUrl     String?
  resetToken       String?
  resetTokenExpiry DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Profile details
  city          String?
  address       String?
  dateOfBirth   DateTime?
  gender        String?   // male | female | other
  preferredLanguage String? @default("he") // he | en | ar | ru

  // Verification & security
  emailVerified Boolean   @default(false)
  phoneVerified Boolean   @default(false)
  lastLoginAt   DateTime?

  // Two-factor authentication (TOTP)
  twoFactorSecret       String?   // base32-encoded TOTP secret
  twoFactorEnabled      Boolean   @default(false)
  twoFactorBackupCodes  String?   // JSON array of one-time backup codes (hashed)

  // Preferences
  notificationPreferences String? // JSON: { email: bool, push: bool, sms: bool, whatsapp: bool }

  vehicles      Vehicle[]
  sosEvents     SosEvent[]
  appointments  Appointment[]
  notifications Notification[]
  garageOwner   Garage?   @relation("GarageOwner")
  ownedShares   VehicleShare[] @relation("SharedVehicleOwner")
  sharedVehicles VehicleShare[] @relation("SharedVehicleUser")

  @@index([email])
  @@index([role])
  @@index([city])
}

// ============================================================
// VEHICLES
// ============================================================

model Vehicle {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  nickname          String    // e.g. "ספורטז לבנה"
  manufacturer      String    // e.g. "KIA"
  model             String    // e.g. "SPORTAGE"
  year              Int
  licensePlate      String    @unique
  color             String?
  vin               String?   @unique

  // Document status
  testExpiryDate    DateTime?
  testStatus        String    @default("valid") // valid | expiring | expired
  insuranceExpiry   DateTime?
  insuranceStatus   String    @default("valid") // valid | expiring | expired
  registrationDate  DateTime?

  // Metadata
  isPrimary         Boolean   @default(false)
  mileage           Int?
  fuelType          String?   // petrol | diesel | electric | hybrid
  imageUrl          String?   // Vehicle photo URL (Vercel Blob)
  maintenanceData   String?   // JSON: AI-generated maintenance schedule cache
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  inspections       Inspection[]
  sosEvents         SosEvent[]
  appointments      Appointment[]
  expenses          Expense[]
  drivers           VehicleDriver[]
  documents         Document[]
  shares            VehicleShare[]

  @@index([userId])
  @@index([licensePlate])
  @@index([testExpiryDate])
  @@index([insuranceExpiry])
}

model VehicleDriver {
  id          String   @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverName  String
  driverPhone String?
  driverLicense String?
  relationship String? // owner | spouse | child | employee
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model VehicleShare {
  id              String   @id @default(cuid())
  vehicleId       String
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  ownerUserId     String
  owner           User     @relation("SharedVehicleOwner", fields: [ownerUserId], references: [id])
  sharedWithEmail String
  sharedWithUserId String?
  sharedUser      User?    @relation("SharedVehicleUser", fields: [sharedWithUserId], references: [id])
  status          String   @default("pending") // pending | approved | rejected
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([vehicleId, sharedWithEmail])
  @@index([ownerUserId])
  @@index([sharedWithEmail])
  @@index([sharedWithUserId])
  @@index([status])
}

// ============================================================
// GARAGES & INSPECTIONS
// ============================================================

model Garage {
  id            String    @id @default(cuid())
  ownerId       String?   @unique
  owner         User?     @relation("GarageOwner", fields: [ownerId], references: [id])
  name          String
  address       String?
  city          String
  phone         String?
  email         String?
  description   String?
  rating        Float     @default(0)
  reviewCount   Int       @default(0)
  services      String?   // JSON array of services
  workingHours  String?   // JSON object
  latitude      Float?
  longitude     Float?
  isActive      Boolean   @default(true)
  isPartner     Boolean   @default(false)
  amenities     String?   // JSON array: ["coffee", "shuttle", "wifi", "waiting_room", "tv", "children_area"]
  imageUrl      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Branding & media
  logoUrl       String?
  galleryImages String?   // JSON array of image URLs
  coverImageUrl String?   // Banner image for garage profile page

  // Business identity
  businessLicense String? // מספר רישיון עסק
  taxId         String?   // ח.פ / מספר עוסק
  foundedYear   Int?

  // Specializations & capabilities
  specializations String? // JSON array: ["toyota", "hyundai", "european", "electric", "diesel", "hybrid"]
  vehicleBrands   String? // JSON array: ["KIA", "Toyota", "Hyundai", "BMW", ...]
  certifications  String? // JSON array: ["MOT_certified", "manufacturer_authorized", "electric_certified"]

  // Team
  mechanics     GarageMechanic[]

  // Pricing & payment
  priceList     String?   // JSON array: [{ service: "טסט שנתי", price: 350, duration: "45 דקות" }, ...]
  paymentMethods String?  // JSON array: ["cash", "credit", "bit", "paybox", "bank_transfer"]
  priceRange    String?   // budget | moderate | premium

  // Social & contact
  socialLinks   String?   // JSON: { website, facebook, instagram, whatsapp, waze, googleMaps }
  whatsappNumber String?  // Direct WhatsApp business number

  inspections   Inspection[]
  appointments  Appointment[]
  reviews       GarageReview[]

  @@index([ownerId])
  @@index([city])
  @@index([rating])
}

model GarageMechanic {
  id          String    @id @default(cuid())
  garageId    String
  garage      Garage    @relation(fields: [garageId], references: [id], onDelete: Cascade)
  fullName    String
  phone       String?
  role        String    @default("mechanic") // mechanic | senior_mechanic | manager | inspector
  specialization String? // engine | electrical | bodywork | tires | general
  avatarUrl   String?
  isActive    Boolean   @default(true)
  startDate   DateTime?
  createdAt   DateTime  @default(now())

  @@index([garageId])
}

model Inspection {
  id              String    @id @default(cuid())
  vehicleId       String
  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  garageId        String
  garage          Garage    @relation(fields: [garageId], references: [id])
  appointmentId   String?   // Optional link to appointment
  mechanicName    String?
  inspectionType  String    // full | rot | engine | tires | brakes | pre_test
  date            DateTime
  status          String    @default("pending") // pending | in_progress | completed | cancelled
  overallScore    Int?      // 0-100

  // Detailed scores (JSON)
  detailedScores  String?   // JSON: { engine: 85, brakes: 90, tires: 75, ... }

  // Vehicle info snapshot
  mileage         Int?
  engineNumber    String?
  engineVerified  Boolean   @default(false)

  // Photos (JSON arrays of base64/URL strings)
  exteriorPhotos  String?   // JSON: { front, rear, right, left, roof }
  interiorPhotos  String?   // JSON: { frontSeats, rearSeats, dashboard }
  undercarVideo   String?   // URL or base64 of undercarriage video

  // Detailed system checks (JSON objects)
  tiresData       String?   // JSON: { frontLeft, frontRight, rearLeft, rearRight } with status
  lightsData      String?   // JSON: { brakes, reverse, fog, headlights, frontSignal, rearSignal, highBeam, plate }
  frontAxle       String?   // JSON: { status, ballBearings, notes }
  steeringData    String?   // JSON: { status, alignment, notes }
  shocksData      String?   // JSON: { frontLeft, frontRight, rearLeft, rearRight, notes }
  bodyData        String?   // JSON: { condition, paintRepairs, partsReplaced, notes }
  batteryData     String?   // JSON: { date, isOriginal }
  fluidsData      String?   // JSON: { brakeFluid, engineOil, coolant } each with status
  interiorSystems String?   // JSON: { acCold, acHot, audio } each with status
  windowsData     String?   // JSON: { rearLeft, rearRight, frontLeft, frontRight } each with status
  engineIssues    String?   // JSON: { issues: [], notes }
  gearboxIssues   String?   // JSON: { issues: [], notes }
  brakingSystem   String?   // JSON: { frontDiscs, rearDiscs, frontPads, rearPads } as percentages

  // Pre-test checklist data
  preTestChecklist String?   // JSON: { tires: boolean, lights: boolean, ... }
  preTestNotes    String?
  serviceItems    String?   // JSON array of service item strings
  workPerformed   String?   // JSON array of { item: string, action: 'fixed'|'replaced'|'adjusted'|'checked'|'cleaned', notes?: string, cost?: number }

  // Results
  summary         String?
  recommendations String?   // JSON array with { text, urgency, estimatedCost }
  notes           String?   // JSON: { undercarriage, engine, general }
  photos          String?   // JSON array of URLs (legacy)
  pdfReportUrl    String?

  // Customer signature
  customerName    String?
  customerIdNumber String?
  customerSignature String?  // base64 signature image
  signedAt        DateTime?

  // AI summary
  aiSummary       String?   // AI-generated smart summary

  cost            Float?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  items           InspectionItem[]

  @@index([vehicleId])
  @@index([garageId])
  @@index([status])
  @@index([createdAt])
  @@index([date])
}

model InspectionItem {
  id            String    @id @default(cuid())
  inspectionId  String
  inspection    Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  category      String    // engine | brakes | tires | suspension | electrical | body | fluids
  itemName      String
  status        String    // ok | warning | critical
  notes         String?
  score         Int?      // 0-100
}

// ============================================================
// APPOINTMENTS
// ============================================================

model Appointment {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleId   String
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])
  garageId    String
  garage      Garage    @relation(fields: [garageId], references: [id])
  serviceType String    // inspection | maintenance | repair | test_prep
  date        DateTime
  time        String
  mechanicId  String?   // optional assigned mechanic (for conflict detection)
  status      String    @default("pending") // pending | confirmed | in_progress | completed | cancelled
  notes       String?
  completionNotes  String?   // Treatment summary written by garage when completing
  completedAt      DateTime? // When the appointment was marked as completed
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([garageId])
  @@index([userId])
  @@index([status])
  @@index([date])
}

// ============================================================
// SOS EVENTS
// ============================================================

model SosEvent {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleId   String
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])
  eventType   String    // accident | breakdown | flat_tire | fuel | electrical | other
  description String?
  location    String?
  latitude    Float?
  longitude   Float?
  status      String    @default("open") // open | assigned | in_progress | resolved
  priority    String    @default("medium") // low | medium | high | critical
  assignedTo  String?
  resolvedAt  DateTime?
  notes       String?   // Updates and notes from user or admin
  photos      String?   // JSON array
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

// ============================================================
// CLUB & BENEFITS
// ============================================================

model ClubBenefit {
  id          String    @id @default(cuid())
  name        String
  category    String    // fuel | insurance | tires | accessories | services
  discount    String
  description String?
  partnerName String?
  icon        String?
  expiryDate  DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
}

// ============================================================
// EXPENSES
// ============================================================

model Expense {
  id          String    @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  category    String    // fuel | maintenance | insurance | test | parking | fines | other
  amount      Float
  description String?
  date        DateTime
  receiptUrl  String?
  treatmentId String?   @unique
  treatment   Treatment? @relation(fields: [treatmentId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([vehicleId])
  @@index([category])
  @@index([date])
}

// ============================================================
// REVIEWS
// ============================================================

model GarageReview {
  id          String    @id @default(cuid())
  garageId    String
  garage      Garage    @relation(fields: [garageId], references: [id], onDelete: Cascade)
  userName    String
  rating      Int       // 1-5
  comment     String?
  createdAt   DateTime  @default(now())

  @@index([garageId])
}

// ============================================================
// DOCUMENTS
// ============================================================

model Document {
  id          String    @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type        String    // insurance_compulsory | insurance_comprehensive | insurance_third_party | license | registration | test_certificate | receipt | photo | other
  title       String
  description String?
  fileUrl     String?   // URL or base64 data
  fileName    String?
  fileType    String?   // image/jpeg, application/pdf, etc.
  expiryDate  DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([vehicleId])
  @@index([type])
  @@index([expiryDate])
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String    // test_expiry | insurance_expiry | appointment | sos | benefit | system
  title       String
  message     String
  isRead      Boolean   @default(false)
  link        String?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([userId, isRead])
  @@index([createdAt])
}

// ============================================================
// GARAGE APPLICATIONS
// ============================================================

model GarageApplication {
  id              String    @id @default(cuid())
  garageName      String
  ownerName       String
  email           String
  phone           String
  city            String
  address         String?
  description     String?
  services        String?
  languages       String?
  yearsExperience Int       @default(0)
  employeeCount   Int       @default(1)
  licenseNumber   String?
  businessNumber  String?   // ח.פ - Israeli company/business number (9 digits)
  images          String?
  status          String    @default("pending") // pending | approved | rejected
  adminNotes      String?
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ============================================================
// TREATMENTS
// ============================================================

model Treatment {
  id              String    @id @default(cuid())
  vehicleId       String
  userId          String
  garageId        String?
  garageName      String?
  mechanicName    String?
  type            String    @default("maintenance") // maintenance | repair | inspection | other
  title           String
  description     String?
  items           String?   // JSON array of treatment items
  mileage         Int?
  cost            Float?
  date            String
  status          String    @default("draft") // draft | pending_approval | approved | rejected
  sentByGarage    Boolean   @default(false)
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  notes           String?
  expense         Expense?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([vehicleId])
  @@index([userId])
  @@index([garageId])
  @@index([status])
}

// ============================================================
// BENEFIT REDEMPTIONS
// ============================================================

model BenefitRedemption {
  id          String    @id @default(cuid())
  benefitId   String
  userId      String
  code        String    @unique
  qrData      String?
  benefitName String
  partnerName String?
  discount    String?
  status      String    @default("active") // active | used | expired
  usedAt      DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([code])
  @@index([status])
}

// ============================================================
// MAINTENANCE TEMPLATES (OEM Service Schedules)
// ============================================================

// ============================================================
// AUDIT LOG (immutable, append-only)
// ============================================================

model AuditLog {
  id            String   @id @default(cuid())
  timestamp     DateTime @default(now())
  action        String   // CREATE | UPDATE | DELETE | LOGIN | LOGOUT | REFRESH_TOKEN | PERMISSION_CHANGE | EXPORT | IMPORT
  userId        String   // actor
  resourceType  String
  resourceId    String
  resourceName  String?
  changes       String?  // JSON { before?, after? }
  ip            String?
  userAgent     String?
  status        String   @default("success") // success | failure
  errorMessage  String?
  metadata      String?  // JSON

  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([action])
  @@index([timestamp])
}

// ============================================================
// MAINTENANCE MODE (global kill-switch by admin)
// ============================================================

model MaintenanceMode {
  id         String   @id @default("singleton")
  enabled    Boolean  @default(false)
  message    String?
  enabledAt  DateTime?
  enabledBy  String?  // admin userId
  updatedAt  DateTime @updatedAt
}

// ============================================================
// APPOINTMENT CONFLICTS guard — optional slot per mechanic
// ============================================================

model MaintenanceTemplate {
  id            String   @id @default(cuid())
  manufacturer  String   // e.g. "סקודה", "יונדאי", "טויוטה"
  model         String   // e.g. "אוקטביה", "i20", "קורולה"
  yearFrom      Int      // model year range start
  yearTo        Int      // model year range end
  fuelType      String?  // gasoline | diesel | hybrid | electric | null=all
  source        String   @default("manual") // manual | oem_pdf | api
  items         String   // JSON array of MaintenanceItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([manufacturer, model, yearFrom, yearTo, fuelType])
  @@index([manufacturer, model])
  @@index([manufacturer])
}
