generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?
  passwordHash  String
  fullName      String
  idNumber      String?   @unique
  licenseNumber String?
  role          String    @default("user") // user | admin | garage_owner
  avatarUrl     String?
  resetToken       String?
  resetTokenExpiry DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Profile details
  city          String?
  address       String?
  dateOfBirth   DateTime?
  gender        String?   // male | female | other
  preferredLanguage String? @default("he") // he | en | ar | ru

  // Verification & security
  emailVerified Boolean   @default(false)
  phoneVerified Boolean   @default(false)
  lastLoginAt   DateTime?

  // Preferences
  notificationPreferences String? // JSON: { email: bool, push: bool, sms: bool, whatsapp: bool }

  vehicles      Vehicle[]
  sosEvents     SosEvent[]
  appointments  Appointment[]
  notifications Notification[]
  garageOwner   Garage?   @relation("GarageOwner")

  @@index([email])
  @@index([role])
  @@index([city])
}

// ============================================================
// VEHICLES
// ============================================================

model Vehicle { id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  nickname          String    // e.g. "ספורטז לבנה"
  manufacturer      String    // e.g. "KIA"
  model             String    // e.g. "SPORTAGE"
  year              Int
  licensePlate      String    @unique
  color             String?
  vin               String?   @unique

  // Document status
  testExpiryDate    DateTime?
  testStatus        String    @default("valid") // valid | expiring | expired
  insuranceExpiry   DateTime?
  insuranceStatus   String    @default("valid") // valid | expiring | expired
  registrationDate  DateTime?

  // Metadata
  isPrimary         Boolean   @default(false)
  mileage           Int?
  fuelType          String?   // petrol | diesel | electric | hybrid
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  inspections       Inspection[]
  sosEvents         SosEvent[]
  appointments      Appointment[]
  expenses          Expense[]
  drivers           VehicleDriver[]
  documents         Document[]

  @@index([userId])
  @@index([licensePlate])
  @@index([testExpiryDate])
  @@index([insuranceExpiry])
}

model VehicleDriver {
  id          String   @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverName  String
  driverPhone String?
  driverLicense String?
  relationship String? // owner | spouse | child | employee
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ============================================================
// GARAGES & INSPECTIONS
// ============================================================

model Garage {
  id            String    @id @default(cuid())
  ownerId       String?   @unique
  owner         User?     @relation("GarageOwner", fields: [ownerId], references: [id])
  name          String
  address       String?
  city          String
  phone         String?
  email         String?
  description   String?
  rating        Float     @default(0)
  reviewCount   Int       @default(0)
  services      String?   // JSON array of services
  workingHours  String?   // JSON object
  latitude      Float?
  longitude     Float?
  isActive      Boolean   @default(true)
  isPartner     Boolean   @default(false)  amenities     String?   // JSON array: ["coffee", "shuttle", "wifi", "waiting_room", "tv", "children_area"]
  imageUrl      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Branding & media
  logoUrl       String?
  galleryImages String?   // JSON array of image URLs
  coverImageUrl String?   // Banner image for garage profile page

  // Business identity
  businessLicense String? // מספר רישיון עסק
  taxId         String?   // ח.פ / מספר עוסק
  foundedYear   Int?

  // Specializations & capabilities
  specializations String? // JSON array: ["toyota", "hyundai", "european", "electric", "diesel", "hybrid"]
  vehicleBrands   String? // JSON array: ["KIA", "Toyota", "Hyundai", "BMW", ...]
  certifications  String? // JSON array: ["MOT_certified", "manufacturer_authorized", "electric_certified"]

  // Team
  mechanics     GarageMechanic[]

  // Pricing & payment
  priceList     String?   // JSON array: [{ service: "טסט שנתי", price: 350, duration: "45 דקות" }, ...]
  paymentMethods String?  // JSON array: ["cash", "credit", "bit", "paybox", "bank_transfer"]
  priceRange    String?   // budget | moderate | premium

  // Social & contact
  socialLinks   String?   // JSON: { website, facebook, instagram, whatsapp, waze, googleMaps }
  whatsappNumber String?  // Direct WhatsApp business number

  inspections   Inspection[]
  appointments  Appointment[]
  reviews       GarageReview[]

  @@index([ownerId])
  @@index([city])
  @@index([rating])
}

model GarageMechanic {
  id          String    @id @default(cuid())
  garageId    String
  garage      Garage    @relation(fields: [garageId], references: [id], onDelete: Cascade)
  fullName    String
  phone       String?
  role        String    @default("mechanic") // mechanic | senior_mechanic | manager | inspector
  specialization String? // engine | electrical | bodywork | tires | general
  avatarUrl   String?
  isActive    Boolean   @default(true)
  startDate   DateTime?
  createdAt   DateTime  @default(now())

  @@index([garageId])
}

model Inspection {
  id              String    @id @default(cuid())
  vehicleId       String
  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  garageId        String
  garage          Garage    @relation(fields: [garageId], references: [id])
  appointmentId   String?   // Optional link to appointment
  mechanicName    String?
  inspectionType  String    // full | rot | engine | tires | brakes | pre_test
  date            DateTime
  status          String    @default("pending") // pending | in_progress | completed | cancelled
  overallScore    Int?      // 0-100\n  // Detailed scores (JSON)\n  detailedScores  String?   // JSON: { engine: 85, brakes: 90, tires: 75, ... }\n\n  // Vehicle info snapshot\n  mileage         Int?\n  engineNumber    String?\n  engineVerified  Boolean   @default(false)\n\n  // Photos (JSON arrays of base64/URL strings)\n  exteriorPhotos  String?   // JSON: { front, rear, right, left, roof }\n  interiorPhotos  String?   // JSON: { frontSeats, rearSeats, dashboard }\n  undercarVideo   String?   // URL or base64 of undercarriage video\n\n  // Detailed system checks (JSON objects)\n  tiresData       String?   // JSON: { frontLeft, frontRight, rearLeft, rearRight } with status\n  lightsData      String?   // JSON: { brakes, reverse, fog, headlights, frontSignal, rearSignal, highBeam, plate }\n  frontAxle       String?   // JSON: { status, ballBearings, notes }\n  steeringData    String?   // JSON: { status, alignment, notes }\n  shocksData      String?   // JSON: { frontLeft, frontRight, rearLeft, rearRight, notes }\n  bodyData        String?   // JSON: { condition, paintRepairs, partsReplaced, notes }\n  batteryData     String?   // JSON: { date, isOriginal }\n  fluidsData      String?   // JSON: { brakeFluid, engineOil, coolant } each with status\n  interiorSystems String?   // JSON: { acCold, acHot, audio } each with status\n  windowsData     String?   // JSON: { rearLeft, rearRight, frontLeft, frontRight } each with status\n  engineIssues    String?   // JSON: { issues: [], notes }\n  gearboxIssues   String?   // JSON: { issues: [], notes }\n  brakingSystem   String?   // JSON: { frontDiscs, rearDiscs, frontPads, rearPads } as percentages\n\n  // Pre-test checklist data\n  preTestChecklist String?   // JSON: { tires: boolean, lights: boolean, ... }\n  preTestNotes    String?\n  serviceItems    String?   // JSON array of service item strings\n  workPerformed   String?   // JSON array of { item: string, action: "fixed"|"replaced"|"adjusted"|"checked"|"cleaned", notes?: string, cost?: number }\n\n  // Results\n  summary         String?\n  recommendations String?   // JSON array with { text, urgency, estimatedCost }\n  notes           String?   // JSON: { undercarriage, engine, general }\n  photos          String?   // JSON array of URLs (legacy)\n  pdfReportUrl    String?\n\n  // Customer signature\n  customerName    String?\n  customerIdNumber String?\n  customerSignature String?  // base64 signature image\n  signedAt        DateTime?\n\n  // AI summary\n  aiSummary       String?   // AI-generated smart summary\n\n  cost            Float?\n  createdAt       DateTime  @default(now())\n  updatedAt       DateTime  @updatedAt\n\n  items           InspectionItem[]\n\n  @@index([vehicleId])\n  @@index([garageId])\n  @@index([status])\n  @@index([createdAt])\n  @@index([date])\n}\n\nmodel InspectionItem {\n  id            String    @id @default(cuid())\n  inspectionId  String\n  inspection    Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)\n  category      String    // engine | brakes | tires | suspension | electrical | body | fluids\n  itemName      String\n  status        String    // ok | warning | critical\n  notes         String?\n  score         Int?      // 0-100\n}\n\n// ============================================================\n// APPOINTMENTS\n// ============================================================\n\nmodel Appointment {\n  id          String    @id @default(cuid())\n  userId      String\n  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)\n  vehicleId   String\n  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])\n  garageId    String\n  garage      Garage    @relation(fields: [garageId], references: [id])\n  serviceType String    // inspection | maintenance | repair | test_prep\n  date        DateTime\n  time        String\n  status      String    @default("pending") // pending | confirmed | in_progress | completed | cancelled\n  notes       String?\n  completionNotes  String?   // Treatment summary written by garage when completing\n  completedAt      DateTime? // When the appointment was marked as completed\n  createdAt   DateTime  @default(now())\n  updatedAt   DateTime  @updatedAt\n\n  @@index([garageId])\n  @@index([userId])\n  @@index([status])\n  @@index([date])\n}\n\n// ============================================================\n// SOS EVENTS\n// ============================================================\n\nmodel SosEvent {\n  id          String    @id @default(cuid())\n  userId      String\n  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)\n  vehicleId   String\n  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])\n  eventType   String    // accident | breakdown | flat_tire | fuel | electrical | other\n  description String?\n  location    String?\n  latitude    Float?\n  longitude   Float?\n  status      String    @default("open") // open | assigned | in_progress | resolved\n  priority    String    @default("medium") // low | medium | high | critical\n  assignedTo  String?\n  resolvedAt  DateTime?\n  notes       String?   // Updates and notes from user or admin\n  photos      String?   // JSON array\n  createdAt   DateTime  @default(now())\n  updatedAt   DateTime  @updatedAt\n\n  @@index([userId])\n  @@index([status])\n}\n\n// ============================================================\n// CLUB & BENEFITS\n// ============================================================\n\nmodel ClubBenefit {\n  id          String    @id @default(cuid())\n  name        String\n  category    String    // fuel | insurance | tires | accessories | services\n  discount    String\n  description String?\n  partnerName String?\n  icon        String?\n  expiryDate  DateTime?\n  isActive    Boolean   @default(true)\n  createdAt   DateTime  @default(now())\n}\n\n// ============================================================\n// EXPENSES\n// ============================================================\n\nmodel Expense {\n  id          String    @id @default(cuid())\n  vehicleId   String\n  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)\n  category    String    // fuel | maintenance | insurance | test | parking | fines | other\n  amount      Float\n  description String?\n  date        DateTime\n  receiptUrl  String?\n  createdAt   DateTime  @default(now())\n\n  @@index([vehicleId])\n  @@index([category])\n  @@index([date])\n}\n\n// ============================================================\n// REVIEWS\n// ============================================================\n\nmodel GarageReview {\n  id          String    @id @default(cuid())\n  garageId    String\n  garage      Garage    @relation(fields: [garageId], references: [id], onDelete: Cascade)\n  userName    String\n  rating      Int       // 1-5\n  comment     String?\n  createdAt   DateTime  @default(now())\n\n  @@index([garageId])\n}\n\n// ============================================================\n// DOCUMENTS\n// ============================================================\n\nmodel Document {\n  id          String    @id @default(cuid())\n  vehicleId   String\n  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)\n  type        String    // insurance_compulsory | insurance_comprehensive | insurance_third_party | license | registration | test_certificate | receipt | photo | other\n  title       String\n  description String?\n  fileUrl     String?   // URL or base64 data\n  fileName    String?\n  fileType    String?   // image/jpeg, application/pdf, etc.\n  expiryDate  DateTime?\n  isActive    Boolean   @default(true)\n  createdAt   DateTime  @default(now())\n  updatedAt   DateTime  @updatedAt\n\n  @@index([vehicleId])\n  @@index([type])\n  @@index([expiryDate])\n}\n\n// ============================================================\n// NOTIFICATIONS\n// ============================================================\n\nmodel Notification {\n  id          String    @id @default(cuid())\n  userId      String\n  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)\n  type        String    // test_expiry | insurance_expiry | appointment | sos | benefit | system\n  title       String\n  message     String\n  isRead      Boolean   @default(false)\n  link        String?\n  createdAt   DateTime  @default(now())\n\n  @@index([userId])\n  @@index([isRead])\n  @@index([userId, isRead])\n  @@index([createdAt])\n}\n\n// ============================================================\n// GARAGE APPLICATIONS\n// ============================================================\n\nmodel GarageApplication {\n  id              String    @id @default(cuid())\n  garageName      String\n  ownerName       String\n  email           String\n  phone           String\n  city            String\n  address         String?\n  description     String?\n  services        String?\n  languages       String?\n  yearsExperience Int       @default(0)\n  employeeCount   Int       @default(1)\n  licenseNumber   String?\n  images          String?\n  status          String    @default("pending") // pending | approved | rejected\n  adminNotes      String?\n  reviewedBy      String?\n  reviewedAt      DateTime?\n  createdAt       DateTime  @default(now())\n  updatedAt       DateTime  @updatedAt\n}\n\n// ============================================================\n// TREATMENTS\n// ============================================================\n\nmodel Treatment {\n  id              String    @id @default(cuid())\n  vehicleId       String\n  userId          String\n  garageId        String?\n  garageName      String?\n  mechanicName    String?\n  type            String    @default("maintenance") // maintenance | repair | inspection | other\n  title           String\n  description     String?\n  items           String?   // JSON array of treatment items\n  mileage         Int?\n  cost            Float?\n  date            String\n  status          String    @default("draft") // draft | pending_approval | approved | rejected\n  sentByGarage    Boolean   @default(false)\n  approvedAt      DateTime?\n  rejectedAt      DateTime?\n  rejectionReason String?\n  notes           String?\n  createdAt       DateTime  @default(now())\n  updatedAt       DateTime  @updatedAt\n\n  @@index([vehicleId])\n  @@index([userId])\n  @@index([garageId])\n  @@index([status])\n}\n\n// ============================================================\n// BENEFIT REDEMPTIONS\n// ============================================================\n\nmodel BenefitRedemption {\n  id          String    @id @default(cuid())\n  benefitId   String\n  userId      String\n  code        String    @unique\n  qrData      String?\n  benefitName String\n  partnerName String?\n  discount    String?\n  status      String    @default("active") // active | used | expired\n  usedAt      DateTime?\n  expiresAt   DateTime?\n  createdAt   DateTime  @default(now())\n\n  @@index([userId])\n  @@index([code])\n  @@index([status])\n}